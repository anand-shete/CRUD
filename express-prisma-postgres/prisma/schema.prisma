generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid()) @db.Uuid // @id means PK
  username  String    @unique
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]

  // @@index([username, id])   // composite index
}

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade) // only for prisma typesafety
  userId      String   @db.Uuid
  tasks       Task[]
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  status      TaskStatus   @default(IN_PROGRESS)
  priority    TaskPriority @default(LOW)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade) // deleting a Project will delete its Task
  projectId   String       @db.Uuid
}

enum TaskStatus {
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  HIGH
  CRITICAL
}
