// Documentations
// Prisma schema: https://www.prisma.io/docs/orm/reference/prisma-schema-reference

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma" // todo this should be removed because prismaClient must be generated inside @prisma/client
}

// what about prod?

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URI")
}

model User {
  id        Int       @id @default(autoincrement()) // @id fields are also indexed automatically 
  name      String
  email     String    @unique // unique fields are indexed automatically
  password  String
  role      UserRole  @default(user)
  createdAt DateTime  @default(now())
  posts     Post[] // A user can write many posts
  comments  Comment[]
}

model Post {
  id         Int        @id @default(autoincrement())
  title      String     @db.VarChar(50)
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade) // delete posts when user is deleted
  authorId   Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  comments   Comment[]
  categories Category[]
}

model Category {
  id    Int          @id @default(autoincrement())
  name  PostCategory
  posts Post[]
}

model Comment {
  id        Int  @id @default(autoincrement())
  user      User @relation(fields: [createdBy], references: [id])
  createdBy Int
  post      Post @relation(fields: [postId], references: [id])
  postId    Int
}

enum UserRole {
  admin
  user
}

enum PostCategory {
  romance
  sci_fi
  thriller
  mystery
}
